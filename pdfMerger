import tkinter as tk
from tkinter import filedialog, messagebox, ttk
from pypdf import PdfWriter

archivos = []

def seleccionar_archivos():
    seleccionados = filedialog.askopenfilenames(filetypes=[("Archivos PDF", "*.pdf")])
    if seleccionados:
        archivos.clear()
        archivos.extend(seleccionados)
        lista.delete(0, tk.END)
        for pdf in archivos:
            lista.insert(tk.END, pdf)

def fusionar():
    if not archivos:
        messagebox.showerror("Error", "No se seleccionaron archivos PDF")
        return

    salida = filedialog.asksaveasfilename(defaultextension=".pdf", filetypes=[("PDF", "*.pdf")])
    if not salida:
        return

    try:
        merger = PdfWriter()
        for pdf in archivos:
            merger.append(pdf)
        merger.write(salida)
        merger.close()
        messagebox.showinfo("Éxito", f"PDFs fusionados en:\n{salida}")
    except Exception as e:
        messagebox.showerror("Error", f"No se pudo fusionar:\n{e}")

app = tk.Tk()
app.title("DELTA PDF Merger")
app.geometry("500x450")
app.resizable(True, False)

bg_color = "#1e1e1e"
fg_color = "#d4d4d4"
accent_color = "#3a3d41"
btn_color = "#3d3d3d"
highlight = "#696969"

app.configure(bg=bg_color)

estilo = ttk.Style(app)
estilo.theme_use("clam")

estilo.configure("TFrame", background=bg_color)
estilo.configure("TLabel", background=bg_color, foreground=fg_color)
estilo.configure("TButton", background=btn_color, foreground=fg_color, focuscolor=highlight, relief="flat")
estilo.map("TButton",
           background=[("active", accent_color)],
           foreground=[("active", fg_color)])

frame = ttk.Frame(app, padding=20)
frame.pack(fill="both", expand=True)

ttk.Label(frame, text="Fusionador de PDFs", font=("Segoe UI", 20)).pack(pady=(0, 5))
ttk.Label(frame, text="by Delta Development and Design", font=("Segoe UI", 10)).pack(pady=(0, 40))

btn_seleccionar = ttk.Button(frame, text="Seleccionar PDFs", command=seleccionar_archivos)
btn_seleccionar.pack(fill="x")

lista_frame = ttk.Frame(frame)
lista_frame.pack(fill="both", expand=True, pady=10)

scroll = ttk.Scrollbar(lista_frame)
scroll.pack(side="right", fill="y")

lista = tk.Listbox(
    lista_frame,
    height=8,
    yscrollcommand=scroll.set,
    font=("Segoe UI", 10),
    bg=accent_color,
    fg=fg_color,
    selectbackground=highlight,
    selectforeground=fg_color,
    border=0,
    relief="flat",
)
lista.pack(fill="both", expand=True)
scroll.config(command=lista.yview)

btn_fusionar = ttk.Button(frame, text="Fusionar PDFs", command=fusionar)
btn_fusionar.pack(fill="x", pady=10)

app.mainloop()
